# -------------------------------------

# VS Code
.vscode/
.settings/

# PyCharm / IntelliJ
.idea/
*.iml

# -------------------------------------
# Codespaces / Devcontainers
# -------------------------------------
.devcontainer/ # (Opcional; mantenlo si quieres versionarlo)
*.code-workspace

# Docker (por si llegas a agregarlo)
*.dockerfile
*.env

